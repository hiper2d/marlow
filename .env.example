# Copy to .env and fill in. .env is gitignored.

# ─── Telegram notification channel ────────────────────────────────────────
# Create a bot via @BotFather on Telegram, then send your bot any message
# and visit https://api.telegram.org/bot<TOKEN>/getUpdates to find chat.id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Calorie tracker bot (separate from the notify bot above) ─────────────
# A distinct @BotFather bot so food traffic stays off the alert channel.
MARLOW_FITNESS_BOT_TOKEN=
MARLOW_FITNESS_CHAT_ID=
# Optional: CALORIE_WHISPER_MODEL (default `small`), CALORIE_TZ (default America/New_York).

# ─── Discord bot (server posting + management for "AI Werewolf and other ──
# projects" community). Create at discord.com/developers/applications → your
# app → Bot → Reset Token. Unverified is fine under 100 servers; full REST API
# access. Invite with the permissions you want (Send Messages, Manage Channels,
# Manage Messages, Moderate Members...). In prod this lives in the launchd plist.
DISCORD_MARLOW_TOKEN=

# ─── Provider API keys (added as we roll out budget plugins) ──────────────
# See plans/budget-providers.md for which are wired and which still need keys.
ANTHROPIC_ADMIN_KEY=
OPENAI_ADMIN_KEY=
DEEPSEEK_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=
MOONSHOT_API_KEY=
MISTRAL_API_KEY=
ZAI_API_KEY=

# ─── Werewolf DB (read-only credentials) ──────────────────────────────────
# NOTE: obsolete. The game stores everything in Firestore, not SQL — these are
# unused. monitor_keys/werewolf_stats/monitor_health read Firestore via
# MARLOW_FIREBASE_CREDS (a path, set in the launchd plist, not here).
WEREWOLF_DB_HOST=
WEREWOLF_DB_NAME=
WEREWOLF_DB_USER=
WEREWOLF_DB_PASSWORD=

# ─── Betterstack app-log query (monitor_betterstack) ──────────────────────
# Read-only ClickHouse query connection for the Werewolf app's logs. Create it
# at Telemetry → Integrations → SQL API → "Connect ClickHouse HTTP client"; the
# password is shown ONCE on creation. This is NOT the app's BETTER_STACK_SOURCE_
# TOKEN (that's ingest-only). In prod these live in the launchd plist.
BETTERSTACK_CH_HOST=
BETTERSTACK_CH_USER=
BETTERSTACK_CH_PASS=
# Optional overrides (defaults baked into handlers/monitor_betterstack.py):
# BETTERSTACK_CH_TABLE=s3Cluster(primary, t507167_ai_werewolf_2_s3)
# BETTERSTACK_WINDOW_MIN=90

# ─── X / Twitter posting (handlers/x.py — DORMANT) ────────────────────────
# Part of the retired news-crosspost auto-post loop (2026-06-05). Kept dormant;
# only needed if X co-posting is ever revived. Uses its own logged-in Chrome
# profile on a dedicated CDP port so it never collides with the scrape profile.
# MARLOW_X_PROFILE=~/.config/marlow/x-profile   (default)
# X_CDP_PORT=9224                               (default)
