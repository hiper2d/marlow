# IDE
.idea/
.vscode/

# macOS
.DS_Store

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Secrets
.env
.env.local

# Logs
*.log

# Runtime state — agent's working files, not source
tasks/queue.json
tasks/queue.*.json
tasks/completed/*
!tasks/completed/.gitkeep
tasks/last_scheduled.json
tasks/last_scheduled.*.json
tasks/telegram_offset.json

# Memory — runtime, agent-written
memory/recent/*
!memory/recent/.gitkeep
memory/archive/*
!memory/archive/.gitkeep

# Astro build artifacts
projects/blog/site/dist/
projects/blog/site/.astro/
projects/blog/site/node_modules/

# Notify fallback log (only created when Telegram delivery fails)
digests/_notify_fallback.log

# Per-feed last-seen state (runtime; fresh clone re-scans cold)
projects/research/threads/_feed_state.json

# YouTube transcript cache (runtime; bulky + regenerable from captions)
projects/research/threads/_yt_transcripts/

# Werewolf API-budget snapshots (runtime; written every monitor run)
projects/werewolf-ops/state/*

# Calorie tracker — runtime data: the SQLite log, Alex's food photos,
# and the Telegram poll offset. Personal + regenerable, not source.
projects/calories/calories.db
projects/calories/inbox/
projects/calories/state/

# Substack growth — runtime poll state + pending comment outbox
# (the outbox drains when Alex approves; the dir is kept via .gitkeep)
projects/blog/substack/state.json
projects/blog/substack/outbox/*
!projects/blog/substack/outbox/.gitkeep

# Drafts and published articles are agent-written content;
# uncomment if you'd rather not commit them to git history.
# projects/blog/drafts/*.md
# projects/blog/published/*.md
