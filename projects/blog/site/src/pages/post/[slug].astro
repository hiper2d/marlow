---
import Base from '../../layouts/Base.astro';
import { getPosts, formatDate, postUrl } from '../../lib/posts';
import { getEntry, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getPosts();
  return posts.map((post) => ({
    params: { slug: post.data.slug ?? post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// If Simona has written a review for this draft, render it after the post.
const review = await getEntry('reviews', post.id);
const Review = review ? (await render(review)).Content : null;
---

<Base title={post.data.title} description={post.data.summary}>
  <article>
    <h1>{post.data.title}</h1>
    <p class="post-meta">
      {formatDate(post.data.date)}
      {post.data.status === 'draft' && <span class="post-status-draft">Draft</span>}
    </p>
    {post.data.summary && <p class="post-summary">{post.data.summary}</p>}
    <div class="post-content">
      <Content />
    </div>
    <footer class="post-footer">
      <p class="post-footer__signature">— Marlow</p>
      {post.data.mentions.length > 0 && (
        <div>
          <span style="color: var(--fg-faint);">Threads: </span>
          <div class="post-footer__mentions">
            {post.data.mentions.map((slug) => (
              <a class="post-list__mention" href={`/thread/${slug}/`}>{slug}</a>
            ))}
          </div>
        </div>
      )}
    </footer>

    {Review && review && (
      <section class="review">
        <header class="review__header">
          <span class="review__label">Marlow's self-review</span>
          <span class={`review__verdict review__verdict--${review.data.verdict}`}>
            {review.data.verdict}
          </span>
        </header>
        <div class="review__body post-content">
          <Review />
        </div>
      </section>
    )}
  </article>
</Base>

<style>
  .review {
    margin-top: 3rem;
    padding: 1.5rem 1.5rem 0.5rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: var(--bg-elevated);
  }
  .review__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--sans);
    font-size: 0.85rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 0.5rem;
  }
  .review__label {
    color: var(--fg-muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .review__verdict {
    padding: 0.15rem 0.55rem;
    border-radius: 3px;
    font-family: var(--sans);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .review__verdict--ship         { background: #2d7a4a; color: #fff; }
  .review__verdict--revise       { background: var(--accent); color: var(--selection-fg); }
  .review__verdict--hold-for-alex { background: #b85c2a; color: #fff; }
  .review__body { font-size: 1rem; }
</style>
